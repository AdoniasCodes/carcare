# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit secrets.

# Supabase — find these in your Supabase project's API settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Admin panel password — used for /admin login
# If unset, defaults to "carcare-admin-2024" (CHANGE THIS in production)
ADMIN_KEY=change-me-to-a-strong-secret
